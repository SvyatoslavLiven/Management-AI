generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }

enum PropertyStatus { draft preopening active paused maintenance archived }
enum ReadinessStatus { ready in_preparation not_ready inspection_needed }
enum HousekeepingStatus { clean dirty cleaning_in_progress inspected }
enum MaintenanceStatus { ok warning issue_open out_of_order }
enum OccupancyStatus { vacant occupied reserved blocked }
enum BookingStatus { tentative confirmed checked_in checked_out cancelled no_show }
enum PaymentStatus { unpaid partially_paid paid refunded deposit_held }
enum EventType { check_in check_out early_check_in late_check_out complaint maintenance_issue inspection accident overdue budget_deviation bad_review staff_absence urgent_purchase }
enum Severity { low medium high critical }
enum EventStatus { open in_review action_created resolved closed }
enum ActionType { housekeeping maintenance quality_check guest_request procurement admin financial_check report_preparation approval escalation }
enum Priority { low normal high urgent }
enum ActionStatus { new assigned in_progress waiting done failed cancelled overdue }
enum ActionApprovalStatus { not_required pending approved rejected }
enum AccessRole { central_manager property_manager department_head line_staff finance owner }
enum EmploymentStatus { active probation leave suspended inactive }
enum ShiftType { morning evening night }
enum ShiftStatus { planned active handed_over closed }
enum AttendanceStatus { planned present absent replaced }
enum ReportType { daily weekly monthly shift owner }
enum ReportStatus { draft generated reviewed sent archived }
enum ApprovalType { expense refund compensation procurement critical_action owner_message price_override }
enum ApprovalStatus { pending approved rejected expired }

model Property {
  id String @id @default(cuid())
  name String
  code String @unique
  type String
  location String
  address String
  ownerName String
  managerId String?
  launchDate DateTime
  status PropertyStatus
  operatingMode String
  unitCount Int
  checkInTime String
  checkOutTime String
  notes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  units Unit[]
  employees Employee[]
  bookings Booking[]
  events Event[]
  actions Action[]
  shifts Shift[]
  reports Report[]
  approvals Approval[]
}

model Unit {
  id String @id @default(cuid())
  propertyId String
  name String
  code String
  type String
  floorOrZone String
  capacity Int
  readinessStatus ReadinessStatus
  housekeepingStatus HousekeepingStatus
  maintenanceStatus MaintenanceStatus
  occupancyStatus OccupancyStatus
  bookingBlocked Boolean @default(false)
  lastInspectionAt DateTime?
  lastMaintenanceAt DateTime?
  nextMaintenanceAt DateTime?
  currentBookingId String?
  notes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  property Property @relation(fields: [propertyId], references: [id])
  bookings Booking[]
  events Event[]
  actions Action[]
}

model Guest {
  id String @id @default(cuid())
  fullName String
  phone String
  email String @unique
  language String
  nationality String
  vipFlag Boolean @default(false)
  repeatGuestFlag Boolean @default(false)
  preferences String?
  serviceNotes String?
  complaintNotes String?
  upsellPotential String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bookings Booking[]
  events Event[]
}

model Booking {
  id String @id @default(cuid())
  propertyId String
  unitId String
  guestId String
  channel String
  externalBookingRef String?
  checkInDate DateTime
  checkOutDate DateTime
  guestCount Int
  status BookingStatus
  paymentStatus PaymentStatus
  depositAmount Float
  totalAmount Float
  currency String
  specialRequests String?
  internalNotes String?
  reviewScore Float?
  reviewText String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  property Property @relation(fields: [propertyId], references: [id])
  unit Unit @relation(fields: [unitId], references: [id])
  guest Guest @relation(fields: [guestId], references: [id])
  events Event[]
}

model Event {
  id String @id @default(cuid())
  propertyId String
  unitId String?
  guestId String?
  bookingId String?
  type EventType
  severity Severity
  source String
  title String
  description String
  occurredAt DateTime
  detectedAt DateTime
  status EventStatus
  createdByEmployeeId String?
  assignedManagerId String?
  resolutionSummary String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  property Property @relation(fields: [propertyId], references: [id])
  unit Unit? @relation(fields: [unitId], references: [id])
  guest Guest? @relation(fields: [guestId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])
  actions Action[]
}

model Action {
  id String @id @default(cuid())
  propertyId String
  unitId String?
  eventId String?
  shiftId String?
  type ActionType
  priority Priority
  title String
  description String
  assignedToEmployeeId String
  reviewerEmployeeId String?
  dueAt DateTime
  startedAt DateTime?
  completedAt DateTime?
  status ActionStatus
  checklist Json?
  requiresApproval Boolean @default(false)
  approvalStatus ActionApprovalStatus @default(not_required)
  resultSummary String?
  photoRequired Boolean @default(false)
  attachmentCount Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  property Property @relation(fields: [propertyId], references: [id])
  unit Unit? @relation(fields: [unitId], references: [id])
  event Event? @relation(fields: [eventId], references: [id])
  shift Shift? @relation(fields: [shiftId], references: [id])
  assignedTo Employee @relation("AssignedActions", fields: [assignedToEmployeeId], references: [id])
  reviewer Employee? @relation("ReviewedActions", fields: [reviewerEmployeeId], references: [id])
}

model Employee {
  id String @id @default(cuid())
  propertyId String?
  fullName String
  role String
  department String
  managerId String?
  shiftTypeDefault ShiftType?
  accessRole AccessRole
  phone String
  email String @unique
  employmentStatus EmploymentStatus
  qualityScore Float @default(0)
  violationCount Int @default(0)
  trainingStatus String
  notes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  property Property? @relation(fields: [propertyId], references: [id])
  manager Employee? @relation("EmployeeManager", fields: [managerId], references: [id])
  reports Employee[] @relation("EmployeeManager")
  shiftsSupervised Shift[] @relation("ShiftSupervisor")
  assignedActions Action[] @relation("AssignedActions")
  reviewedActions Action[] @relation("ReviewedActions")
  shiftStaff ShiftStaff[]
  approvalsRequested Approval[] @relation("ApprovalRequester")
  approvalsToDecide Approval[] @relation("ApprovalApprover")
  activities ActivityLog[]
  reportGenerated Report[]
  user User?
}

model Shift {
  id String @id @default(cuid())
  propertyId String
  shiftDate DateTime
  shiftType ShiftType
  supervisorEmployeeId String
  status ShiftStatus
  handoverNotes String?
  incidentSummary String?
  openActionsCount Int @default(0)
  closedActionsCount Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  property Property @relation(fields: [propertyId], references: [id])
  supervisor Employee @relation("ShiftSupervisor", fields: [supervisorEmployeeId], references: [id])
  staff ShiftStaff[]
  actions Action[]
}

model ShiftStaff {
  id String @id @default(cuid())
  shiftId String
  employeeId String
  roleInShift String
  attendanceStatus AttendanceStatus
  replacementForEmployeeId String?
  createdAt DateTime @default(now())
  shift Shift @relation(fields: [shiftId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
}

model Report {
  id String @id @default(cuid())
  propertyId String
  type ReportType
  periodStart DateTime
  periodEnd DateTime
  status ReportStatus
  generatedByEmployeeId String
  ownerVisible Boolean @default(false)
  summary String
  kpi Json
  openRisks String
  sentAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  property Property @relation(fields: [propertyId], references: [id])
  generatedBy Employee @relation(fields: [generatedByEmployeeId], references: [id])
}

model Approval {
  id String @id @default(cuid())
  entityType String
  entityId String
  propertyId String
  requestedByEmployeeId String
  approverEmployeeId String
  approvalType ApprovalType
  status ApprovalStatus
  requestedAt DateTime
  decidedAt DateTime?
  comment String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  property Property @relation(fields: [propertyId], references: [id])
  requestedBy Employee @relation("ApprovalRequester", fields: [requestedByEmployeeId], references: [id])
  approver Employee @relation("ApprovalApprover", fields: [approverEmployeeId], references: [id])
}

model ActivityLog {
  id String @id @default(cuid())
  employeeId String?
  entityType String
  entityId String
  actionType String
  oldValue Json?
  newValue Json?
  createdAt DateTime @default(now())
  ipOrDevice String?
  employee Employee? @relation(fields: [employeeId], references: [id])
}

model User {
  id String @id @default(cuid())
  name String?
  email String? @unique
  emailVerified DateTime?
  image String?
  password String
  employeeId String @unique
  employee Employee @relation(fields: [employeeId], references: [id])
  accounts Account[]
  sessions Session[]
}
model Account {
  id String @id @default(cuid())
  userId String
  type String
  provider String
  providerAccountId String
  refresh_token String?
  access_token String?
  expires_at Int?
  token_type String?
  scope String?
  id_token String?
  session_state String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}
model Session {
  id String @id @default(cuid())
  sessionToken String @unique
  userId String
  expires DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
model VerificationToken {
  identifier String
  token String @unique
  expires DateTime
  @@unique([identifier, token])
}
